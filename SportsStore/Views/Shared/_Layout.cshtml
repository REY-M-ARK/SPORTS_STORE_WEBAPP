<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SportsStore</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SportsStore.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.2.1/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-primary: #0a0a0a;
            --bg-secondary: #111111;
            --bg-card: #161616;
            --bg-hover: #1e1e1e;
            --border-color: #222222;
            --accent: #e8ff00;
            --accent-dim: rgba(232, 255, 0, 0.08);
            --text-primary: #f0f0f0;
            --text-muted: #555555;
            --text-secondary: #888888;
        }

        * {
            box-sizing: border-box;
        }

        body {
            background-color: var(--bg-primary);
            color: var(--text-primary);
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── HEADER ── */
        .site-header {
            background-color: var(--bg-secondary);
            border-bottom: 1px solid var(--border-color);
            padding: 0 2rem;
            height: 64px;
            display: flex;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .site-header .brand {
            font-size: 1.1rem;
            font-weight: 700;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            color: var(--text-primary);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .site-header .brand::before {
            content: '';
            width: 8px;
            height: 8px;
            background: var(--accent);
            border-radius: 50%;
            display: inline-block;
        }

        .site-header .header-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        /* ── LAYOUT ── */
        .site-body {
            display: flex;
            flex: 1;
            min-height: 0;
        }

        /* ── SIDEBAR ── */
        .site-sidebar {
            width: 240px;
            min-width: 240px;
            background-color: var(--bg-secondary);
            border-right: 1px solid var(--border-color);
            padding: 2rem 0;
            display: flex;
            flex-direction: column;
        }

        .sidebar-label {
            font-size: 0.65rem;
            font-weight: 600;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            color: var(--text-muted);
            padding: 0 1.5rem;
            margin-bottom: 0.75rem;
        }

        /* Navigation menu items will be styled via site.css */
        /* These selectors target typical ASP.NET navigation output */
        #categories a,
        #categories .nav-link {
            display: block;
            padding: 0.6rem 1.5rem;
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 400;
            border-left: 2px solid transparent;
            transition: all 0.15s ease;
        }

        #categories a:hover,
        #categories .nav-link:hover {
            color: var(--text-primary);
            background-color: var(--bg-hover);
            border-left-color: var(--accent);
        }

        #categories a.selected,
        #categories .nav-link.active {
            color: var(--text-primary);
            background-color: var(--accent-dim);
            border-left-color: var(--accent);
            font-weight: 500;
        }

        /* ── MAIN CONTENT ── */
        .site-main {
            flex: 1;
            padding: 2rem 2.5rem;
            background-color: var(--bg-primary);
            overflow-y: auto;
        }

        /* ── FOOTER ── */
        .site-footer {
            background-color: var(--bg-secondary);
            border-top: 1px solid var(--border-color);
            padding: 1.25rem 2rem;
            font-size: 0.75rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .site-footer a {
            color: var(--text-muted);
            text-decoration: none;
            transition: color 0.15s;
        }

        .site-footer a:hover {
            color: var(--accent);
        }

        /* ── CART BUTTON ── */
        .cart-widget {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 0.45rem 1rem;
            border-radius: 6px;
            font-size: 0.8rem;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.15s ease;
        }

        .cart-widget:hover {
            border-color: var(--accent);
            color: var(--accent);
            background: var(--accent-dim);
        }

        .cart-widget i {
            font-size: 0.9rem;
        }

        /* ── CARDS & PRODUCTS ── */
        .card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            color: var(--text-primary);
        }

        .card:hover {
            border-color: #2a2a2a;
            box-shadow: 0 4px 24px rgba(0,0,0,0.4);
        }

        .card-header, .card-footer {
            background-color: transparent;
            border-color: var(--border-color);
        }

        /* ── BUTTONS ── */
        .btn-primary {
            background-color: var(--accent);
            border-color: var(--accent);
            color: #000;
            font-weight: 600;
            font-size: 0.8rem;
            letter-spacing: 0.05em;
            border-radius: 5px;
            transition: all 0.15s ease;
        }

        .btn-primary:hover {
            background-color: #d4eb00;
            border-color: #d4eb00;
            color: #000;
        }

        .btn-outline-secondary {
            border-color: var(--border-color);
            color: var(--text-secondary);
            font-size: 0.8rem;
            border-radius: 5px;
        }

        .btn-outline-secondary:hover {
            background-color: var(--bg-hover);
            border-color: #333;
            color: var(--text-primary);
        }

        /* ── TABLES ── */
        .table {
            color: var(--text-primary);
            border-color: var(--border-color);
        }

        .table thead th {
            color: var(--text-muted);
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            border-bottom-color: var(--border-color);
        }

        .table td {
            border-color: var(--border-color);
            vertical-align: middle;
        }

        .table tbody tr:hover {
            background-color: var(--bg-hover);
        }

        /* ── FORMS ── */
        .form-control, .form-select {
            background-color: var(--bg-card);
            border-color: var(--border-color);
            color: var(--text-primary);
            font-size: 0.875rem;
            border-radius: 6px;
        }

        .form-control:focus, .form-select:focus {
            background-color: var(--bg-hover);
            border-color: var(--accent);
            color: var(--text-primary);
            box-shadow: 0 0 0 3px rgba(232,255,0,0.08);
        }

        .form-label {
            font-size: 0.8rem;
            font-weight: 500;
            color: var(--text-secondary);
            letter-spacing: 0.03em;
        }

        /* ── PAGINATION ── */
        .page-link {
            background-color: var(--bg-card);
            border-color: var(--border-color);
            color: var(--text-secondary);
            font-size: 0.8rem;
        }

        .page-link:hover {
            background-color: var(--bg-hover);
            border-color: var(--border-color);
            color: var(--text-primary);
        }

        .page-item.active .page-link {
            background-color: var(--accent);
            border-color: var(--accent);
            color: #000;
        }

        /* ── BADGES ── */
        .badge {
            font-weight: 500;
            font-size: 0.65rem;
            letter-spacing: 0.05em;
        }

        /* ── ALERTS ── */
        .alert {
            border-radius: 6px;
            font-size: 0.875rem;
            border: 1px solid;
        }

        /* ── SCROLLBAR ── */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: var(--bg-primary); }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 2px; }
        ::-webkit-scrollbar-thumb:hover { background: #444; }
    </style>
</head>
<body>

    <!-- HEADER -->
    <header class="site-header">
        <a class="brand" href="/">SPORTS STORE</a>
        <div class="header-right">
            <div class="cart-widget">
                <vc:cart-summary />
            </div>
        </div>
    </header>

    <!-- BODY -->
    <div class="site-body">

        <!-- SIDEBAR -->
        <aside class="site-sidebar">
            <div class="sidebar-label">Categories</div>
            <div id="categories">
                <vc:navigation-menu />
            </div>
        </aside>

        <!-- MAIN -->
        <main class="site-main">
            @RenderBody()
        </main>

    </div>

    <!-- FOOTER -->
    <footer class="site-footer">
        <span>&copy; 2026 REVALDE SPORTS STORE</span>
        <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
